{
	"info": {
		"_postman_id": "8b51d45c-1f59-4d64-839f-1c4b7b25e229",
		"name": "Research Agent API (JWT Auth)",
		"description": "Upgraded API endpoints with Native FastAPI JWT Authentication + Automated Token capture.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"postman_test@example.com\",\n    \"password\": \"securepassword123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "Login User (Auto-sets Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if(pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"access_token\", jsonData.idToken);",
									"    console.log(\"Access Token grabbed and saved automatically!\");",
									"} else {",
									"    console.log(\"Login failed, token not saved.\")",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"postman_test@example.com\",\n    \"password\": \"securepassword123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						}
					},
					"response": []
				},
				{
					"name": "Verify Token",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/verify",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"verify"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Agent Chat",
			"item": [
				{
					"name": "Start Chat (Auto-sets thread_id)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if(pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"thread_id\", jsonData.thread_id);",
									"    pm.collectionVariables.set(\"session_id\", jsonData.thread_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"feasibility of solar drones for reforestation\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/chat/start",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"chat",
								"start"
							]
						}
					},
					"response": []
				},
				{
					"name": "Resume Chat",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"thread_id\": \"{{thread_id}}\",\n    \"user_response\": \"yes that is correct\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/chat/resume",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"chat",
								"resume"
							]
						}
					},
					"response": []
				}
			]
		},
